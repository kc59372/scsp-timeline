# Production environment for docker-compose.prod.yml.
# Copy to .env.production and fill in real secrets. Do NOT commit .env.production.
#
# NOTE: Docker Compose v2 interpolates "$VAR" in env_file values, so any literal
# "$" in a secret (notably the bcrypt ADMIN_PASSWORD_HASH) MUST be escaped as
# "$$" here — otherwise it is silently mangled and admin login fails.
# scripts/hash_password.ts prints the ready-to-paste "$$"-escaped form.

# --- Postgres (read by the db container) ---
POSTGRES_USER=scsp
POSTGRES_DB=scsp_timeline
POSTGRES_PASSWORD=change-me-strong-password

# --- App (read by the web container) ---
# host "db" is the compose service name; password must match POSTGRES_PASSWORD.
DATABASE_URL=postgresql://scsp:change-me-strong-password@db:5432/scsp_timeline?schema=public

# Public base URL of the deployment (used by server components + auth).
NEXT_PUBLIC_SITE_URL=https://timeline.example.org
NEXTAUTH_URL=https://timeline.example.org
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Admin credential (single shared login). Generate the hash with:
#   npx ts-node scripts/hash_password.ts '<password>'
ADMIN_EMAIL=admin@scsp.ai
ADMIN_PASSWORD_HASH=

# Ingest auth — REQUIRED in production so /api/ingest is not open to the public.
# Generate with: openssl rand -hex 32
INGEST_TOKEN=
