# PostgreSQL connection string.
# Matches the docker-compose.yml dev credentials below.
DATABASE_URL="postgresql://scsp:scsp_dev_password@localhost:5432/scsp_timeline?schema=public"

# NextAuth (admin auth — wired up in Phase 5)
NEXTAUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

# Admin auth (Phase 5) — single shared admin credential.
# Generate the hash:  npx ts-node scripts/hash_password.ts '<password>'
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Admin dashboard visibility. The in-app admin UI is HIDDEN by default (review
# happens in Airtable) — every /admin path returns a 404. Set to "true" to bring
# the dashboard + login back.
ADMIN_ENABLED=

# Rate limiting (lib/ratelimit.ts, enforced in middleware.ts on HTML page routes
# to throttle bulk scraping). DISABLED by default — set to "true" to enable.
# In-memory + per-instance: exact on one instance, best-effort when scaled (use
# a Google Cloud Armor policy on the load balancer for exact global limits).
RATE_LIMIT_ENABLED=
RATE_LIMIT_MAX=120        # requests per window, per IP
RATE_LIMIT_WINDOW_SEC=60  # window length in seconds

# Scrapers (Phase 3)
# Free SAM.gov API key: https://open.gsa.gov/api/get-opportunities-public-api/
SAM_GOV_API_KEY=
INGEST_URL="http://localhost:3000/api/ingest"
# Shared secret for /api/ingest. If set, scrapers must send it and the endpoint
# rejects requests without it. REQUIRED in production (see DEPLOY.md); optional
# locally. Generate one with: openssl rand -hex 32
INGEST_TOKEN=

# Ingest verification (lib/verify.ts) — optional.
# The ingest endpoint auto-approves entries that match a curated program with
# high significance and auto-rejects clearly-irrelevant ones. Clear-cut cases
# are decided by rules for free; only ambiguous entries (no AI/autonomy keyword
# signal) are sent to Claude for a relevance check. Set this key to enable that
# LLM tier — without it, ambiguous entries safely default to PENDING (review).
ANTHROPIC_API_KEY=

# Frontend (Phase 4) — base URL server components use to call the public API
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Data-API lock (lib/apiGuard.ts). The public site renders server-side, so the
# JSON API (/api/milestones, /api/programs) has no legitimate direct browser
# caller. When set, those GET endpoints require this token (sent automatically
# by the server-side render) or an admin session — blocking bulk dataset export
# like /api/milestones?pageSize=all. REQUIRED in production; leave unset locally
# to keep the API open for dev. Generate one with: openssl rand -hex 32
INTERNAL_API_TOKEN=

# Airtable review sink (lib/airtable.ts) — entries needing review (PENDING) are
# POSTed to an Airtable table as an extra review surface. The API key is a
# secret and lives here (never hardcoded). The base id + table name are set in
# lib/airtable.ts. Leave unset to disable the Airtable push (ingest still works;
# postToAirtable() no-ops). Personal access token needs the data.records:write
# scope: https://airtable.com/create/tokens
AIRTABLE_API_KEY=
